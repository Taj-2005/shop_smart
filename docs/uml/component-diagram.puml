@startuml ShopSmart_ComponentDiagram
title ShopSmart - Component Diagram

skinparam componentStyle rectangle
skinparam backgroundColor #FAFAFA
skinparam component {
  BackgroundColor #E8F9F7
  BorderColor #00C2B2
}
skinparam ArrowColor #006B63
skinparam shadowing false
skinparam roundcorner 8

' ─── CLIENT SUBSYSTEM ───
package "Client (Vercel - Next.js 16)" as Client {

  package "Pages (App Router)" as Pages {
    [Landing / Shop / Product] as P1
    [Cart / Checkout / Orders] as P2
    [Profile / Wishlist] as P3
    [Login / Signup / ForgotPassword] as P4
    [Admin Dashboard] as P5
    [Super Admin Panel] as P6
  }

  [AuthContext Provider] as AuthCtx
  note right of AuthCtx
    user, login()
    logout(), refresh()
  end note

  [ShopContext Provider] as ShopCtx
  note right of ShopCtx
    cart, wishlist
    addToCart(), removeFromCart()
  end note

  [Axios API Client] as AxiosClient
  note right of AxiosClient
    withCredentials: true
    auto-refresh 401 interceptor
  end note

  [Next.js Middleware] as NXMiddleware
  note right of NXMiddleware
    Pass-through for
    cross-origin cookies
  end note

  Pages --> AuthCtx
  Pages --> ShopCtx
  Pages --> AxiosClient
}

' ─── SERVER SUBSYSTEM ───
package "Server (Render - Express 4)" as Server {

  [Express App - app.ts] as App
  note right of App
    CORS, Helmet, Rate Limit
    Cookie Parser, Swagger UI
  end note

  package "Middleware Layer" as MWLayer {
    [authenticate] as MW1
    [authorize] as MW2
    [validate] as MW3
    [errorHandler] as MW4
    [rateLimit] as MW5
  }

  package "Feature Modules /api" as Modules {
    [Auth Module /api/auth] as AuthMod
    [User Module /api/user] as UserMod
    [Users Module /api/users] as UsersMod
    [Products Module /api/products] as ProdMod
    [Categories Module /api/categories] as CatMod
    [Cart Module /api/cart] as CartMod
    [Orders Module /api/orders] as OrdMod
    [Reviews Module /api/reviews] as RevMod
    [Admin Module /api/admin] as AdminMod
    [Super Admin Module /api/super-admin] as SAMod
  }

  [JWT Utilities] as JWT
  note right of JWT
    signToken()
    verifyToken()
  end note

  [Swagger / OpenAPI Docs /api-docs] as Swagger

  App --> MWLayer
  App --> Modules
  App --> Swagger
  AuthMod --> JWT
  MWLayer --> Modules
}

' ─── INFRASTRUCTURE ───
package "Infrastructure" as Infra {
  [Prisma ORM] as Prisma
  [PostgreSQL - Neon Cloud] as PG
  [Nodemailer SMTP] as Mail
  [GitHub Actions CI/CD] as CICD
}

' ─── CROSS-SUBSYSTEM LINKS ───
AxiosClient --> App : HTTPS REST (withCredentials)
Modules --> Prisma : type-safe queries
Prisma --> PG : SSL/TLS
AuthMod --> Mail : verify / reset / order emails
CICD --> Client : deploy trigger (Vercel)
CICD --> Server : deploy trigger (Render)

@enduml

{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "node_modules/swagger-ui-dist/**",
          "api-static/**"
        ]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "api/index.ts?path=$1" }]
}


sequenceDiagram
    autonumber
    participant B  as Browser / Client
    participant AC as AuthContext (React)
    participant AX as Axios Interceptor
    participant MW as Next.js Middleware
    participant EX as Express Server
    participant AM as authenticate()
    participant AS as AuthService
    participant DB as PostgreSQL

    %% ══════════════════════════════════════════
    rect rgb(232, 249, 247)
        Note over B,DB: ① LOGIN FLOW
        B->>EX: POST /api/auth/login { email, password }
        EX->>AS: login(email, password)
        AS->>DB: SELECT user WHERE email = ?
        DB-->>AS: user record
        AS->>AS: bcrypt.compare(password, hash)
        AS->>AS: check failedLogins / lockedUntil
        AS->>AS: generate accessToken (JWT 1h)
        AS->>AS: generate refreshToken (JWT 30d)
        AS->>DB: INSERT refresh_tokens (hash, userId, expiresAt)
        DB-->>AS: ok
        AS-->>EX: { user, accessToken, refreshToken }
        EX-->>B: "200 Set-Cookie: accessToken=...; HttpOnly; Secure<br/>Set-Cookie: refreshToken=...; HttpOnly; Secure"
        B->>AC: setUser({ id, email, role })
    end

    %% ══════════════════════════════════════════
    rect rgb(255, 248, 230)
        Note over B,DB: ② AUTHENTICATED REQUEST (GET /api/cart)
        B->>AX: GET /api/cart
        AX->>EX: GET /api/cart (cookies sent automatically)
        EX->>AM: authenticate()
        AM->>AM: read req.cookies.accessToken
        AM->>AM: jwt.verify(token, ACCESS_SECRET)
        AM-->>EX: req.user = { id, role }
        EX->>DB: SELECT cart WHERE userId = ?
        DB-->>EX: cart + items
        EX-->>B: 200 { success, cart }
    end

    %% ══════════════════════════════════════════
    rect rgb(255, 235, 235)
        Note over B,DB: ③ TOKEN EXPIRY & REFRESH
        B->>AX: GET /api/orders
        AX->>EX: GET /api/orders (expired accessToken)
        EX->>AM: authenticate()
        AM->>AM: jwt.verify() → TokenExpiredError
        AM-->>EX: 401 Unauthorized
        EX-->>AX: 401 { message: "Token expired" }
        AX->>AX: intercept 401 → queue refresh
        AX->>EX: POST /api/auth/refresh (sends refreshToken cookie)
        EX->>AS: refresh(refreshToken)
        AS->>DB: SELECT refresh_token WHERE hash = ?
        DB-->>AS: token (revoked: false, not expired)
        AS->>AS: generate new accessToken (JWT 1h)
        AS-->>EX: new accessToken
        EX-->>AX: 200 Set-Cookie: accessToken=...(new); HttpOnly
        AX->>EX: GET /api/orders (retry with new cookie)
        EX-->>B: 200 { orders }
    end

    %% ══════════════════════════════════════════
    rect rgb(240, 240, 255)
        Note over B,DB: ④ LOGOUT
        B->>AC: logout()
        AC->>AX: POST /api/auth/logout
        AX->>EX: POST /api/auth/logout (sends refreshToken cookie)
        EX->>AS: logout(refreshToken)
        AS->>DB: UPDATE refresh_tokens SET revoked=true WHERE hash=?
        DB-->>AS: ok
        AS-->>EX: done
        EX-->>B: "200 Set-Cookie: accessToken=...; HttpOnly; Secure<br/>Set-Cookie: refreshToken=...; HttpOnly; Secure"
        B->>AC: clearUser()
        AC->>B: redirect → /login
    end
